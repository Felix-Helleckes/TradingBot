[kraken_api]
key = ""
secret = ""

[bot_settings]
base_currency = "EUR"
auto_select_pair = true
loop_interval_seconds = 60
trade_pairs = [ "XXBTZEUR", "XETHZEUR", "SOLEUR", "XXRPZEUR",]
allocation_per_trade_percent = 20.0

[risk_management]
max_drawdown_percent = 10.0
stop_loss_percent = 1.5
allocation_per_trade_percent = 20.0
min_buy_score = 4.0
# Use mean-reversion only on small accounts
enable_mean_reversion_signals = true
enable_trend_breakout_signals = false
mr_rsi_oversold_threshold = 30
mr_rsi_overbought_threshold = 55
# Disable regime + extra MTF filters to increase trade frequency
enable_regime_filter = false
regime_benchmark_pair = "XBTEUR"
regime_min_score = -10.0
enable_mtf_regime_scoring = false
mtf_regime_min_score = -5.0
enable_hard_stop_loss = true
hard_stop_loss_percent = 1.5
enable_break_even = true
break_even_trigger_percent = 1.5
airbag_drop_threshold = 15.0
airbag_window_minutes = 10
enable_sentiment_guard = false
enable_trading_hours = false
trading_hours_start_utc = 14
trading_hours_end_utc = 22
# reduce volume filters to allow more trades for small account
enable_volume_filter = true
volume_filter_min_ratio = 0.2
enable_time_stop = true
time_stop_hours = 24
enable_daily_drawdown = true
daily_loss_limit_percent = 5.0
risk_off_allocation_multiplier = 0.5
enable_volatility_targeting = false
target_volatility_pct = 1.6
max_consecutive_losses = 3
pause_after_loss_streak_minutes = 60
# Rely on RSI exit, disable aggressive adaptive TP
take_profit_percent = 2.0
adaptive_take_profit = false
max_take_profit_percent = 0.0
sell_fee_buffer_percent = 0.45
fees_maker_percent = 0.16
fees_taker_percent = 0.26
reentry_guard_pairs = [ "VER",]
min_reentry_profit_pct = 0.0
min_net_sell_profit_pct = 0.2
exit_slippage_buffer_pct = 0.35
enable_atr_stop = true
atr_period = 20
atr_multiplier = 1.0
atr_trail_multiplier = 2.0
enable_atr_dynamic_tp = false
atr_tp_multiplier = 2.0
enable_pyramiding = false
pyramiding_add_pct = 0.5
max_open_positions = 1
trade_cooldown_seconds = 1800
global_trade_cooldown_seconds = 1800
empty_sell_log_cooldown_seconds = 1800
min_trade_eur = 10.0
min_free_margin_buffer = 5.0
max_notional_per_side = 25.0
max_open_positions_per_side = 1
enable_parallel_caps = false
min_auto_scale_notional = 0.2
aggressive_autoscale = false
dynamic_notional_fraction = 0.25

[execution]
# How often (seconds) to recompute signals from 1h OHLC.
# 300 s = every 5 min — avoids noisy tick-level signals while staying responsive.
signal_refresh_interval_seconds = 300
# How long (seconds) to cache the regime (RISK_ON/OFF) result.
# Regime changes slowly; 600 s is safe and saves OHLC API calls.
regime_cache_ttl_seconds = 600
# Post-only (maker) limit order timeout before falling back to market order.
enable_live_limit_fallback = true
limit_fallback_timeout_sec = 60
# If true, the execution layer will NOT auto-fallback to taker (market) orders
# when a post-only/limit maker order times out. Useful to measure maker-only fills
# and fee drag on small accounts. Beware: funds may remain reserved in open orders.
prefer_maker_only = true
# Auto-cancel maker orders after this many hours (0 = disabled)
maker_order_auto_cancel_hours = 12
# Spread and depth guards for BUY preflight
max_spread_pct = 0.5
min_book_fill_ratio = 0.5

# ── WebSocket feed ────────────────────────────────────────────────────────────
# Uses Kraken WebSocket v2 for real-time last-prices (no REST call per tick).
# Falls back to REST Ticker polling automatically when the connection drops
# or when the cached WS price is older than 90 seconds.
[websocket]
enable_ws_feed = true

# ── Technical indicators / filters ───────────────────────────────────────────
[technical]
# EMA crossover trend filter
# Blocks new BUYs when the fast EMA is below the slow EMA on the 1h chart.
# Keeps the bot out of clearly downtrending markets.
enable_ema_crossover_filter = false
ema_fast_period = 9   # fast EMA period (1h candles)
ema_slow_period = 21  # slow EMA period (1h candles)

# Multi-timeframe MACD confirmation
# Blocks new BUYs only when BOTH the 1h AND 15m MACD histograms are negative
# (confirmed bearish momentum on two timeframes).
# Using BOTH avoids false blocks during sideways/consolidation phases.
enable_mtf_macd_filter = false

# Partial take-profit exit
# When unrealised profit reaches partial_exit_trigger_pct, sells
# partial_exit_fraction of the position to lock in gains.
# The remaining position continues under the ATR trailing stop.
# Fires only once per entry cycle.
enable_partial_exit = true
partial_exit_trigger_pct = 1.0       # trigger when profit ≥ this % (changed to 1%)
partial_exit_fraction = 0.5          # sell this fraction (0.5 = 50 %)
partial_exit_min_remaining_eur = 5.0 # skip partial exit if remainder < this EUR value

[daytrading]
enable_daytrading = true
max_hold_hours = 12
intraday_sl_percent = 1.5
intraday_tp_percent = 1.8
intraday_cooldown_seconds = 1800
max_consecutive_losses = 2
loss_streak_pause_minutes = 30

[bear_shield]
enable_bear_shield = false
bear_ema_period = 50
bear_confirm_candles = 3
bear_benchmark_pair = "XBTEUR"
bear_log_interval_minutes = 60

[shorting]
enabled = false
leverage = "2"
max_short_notional_eur = 75.0
short_take_profit_percent = 1.0
short_stop_loss_percent = 2.5

[logging]
log_level = "INFO"
log_to_file = true
log_file_path = "logs/bot_activity.log"
fresh_log_on_start = false

[backtesting]
historical_data_path = "data/historical_prices.csv"
results_output_path = "backtest_results/"

[reporting]
generate_trade_reports = true
report_output_path = "reports/"
cashflow_refresh_seconds = 60

[alerts]
notify_on = [ "trade", "error",]
notify_channel = "telegram"
notify_min_profit_pct = 0.0

[paths]
nas_root = "/mnt/fritz_nas/Volume/kraken"
nas_ohlc_2026 = "/mnt/fritz_nas/Volume/kraken/2026"
nas_ohlc_2025 = "/mnt/fritz_nas/Volume/kraken/2025/ohlcvt"
nas_bot_cache = "/mnt/fritz_nas/Volume/kraken/bot_cache"
local_history_buffer = "data/history_buffer.json"

[telegram]
bot_token = ""
chat_id = ""
notify_on = [ "trade", "error", "drawdown",]

[bot_settings.min_volumes]
XXBTZEUR = 0.0001
XETHZEUR = 0.001
SOLEUR = 0.02
XXRPZEUR = 5.0

[bot_settings.trade_amounts]
trade_amount_eur = 20.0
initial_balance = 100.0
target_balance_eur = 10000.0
